# Copie este arquivo para ".env" e preencha os valores

# ── NextAuth / Auth.js ─────────────────────────────────────────────────────────
# Gere um secret seguro com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# URL base do sistema — OBRIGATÓRIO em produção para evitar redirect para localhost
# Use o IP ou domínio onde o sistema está hospedado. Exemplos:
#   http://172.20.10.210:3001
#   http://meuservidor.local:3000
# Em desenvolvimento, pode deixar comentado (Next.js detecta automaticamente).
# AUTH_URL="http://172.20.10.210:3001"

# ── Banco de Dados Principal (PostgreSQL) ──────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/torre-transferencia"

# ── Banco de Telemetria Sascar (SQL Server) ────────────────────────────────────
# Conexão com o banco SQL Server da Sascar para leitura de posições GPS
# TELEMETRIA_DB_URL="Server=IP_SASCAR;Database=NOME_DB;User Id=usuario;Password=senha;TrustServerCertificate=true"

# ── Ambiente ───────────────────────────────────────────────────────────────────
NODE_ENV="production"
